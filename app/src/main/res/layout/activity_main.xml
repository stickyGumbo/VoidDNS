<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VoidDNS"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pi-hole for Android"
            android:textSize="14sp"
            android:textColor="#888888"
            android:layout_gravity="center"
            android:layout_marginBottom="32dp"/>

        <!-- Status Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A1A2E"
            android:padding="24dp"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <View
                android:id="@+id/statusIndicator"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/circle_red"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/statusTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Protection Inactive"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>

            <TextView
                android:id="@+id/statusSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap to enable VoidDNS"
                android:textSize="14sp"
                android:textColor="#888888"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- Toggle Button -->
        <Button
            android:id="@+id/toggleButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Start Protection"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#00C853"
            android:layout_marginBottom="24dp"/>

        <!-- Stats Grid -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STATISTICS"
            android:textSize="12sp"
            android:textColor="#888888"
            android:letterSpacing="0.1"
            android:layout_marginBottom="12dp"/>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="2"
            android:layout_marginBottom="24dp">

            <!-- Blocked -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical"
                android:background="#1A1A2E"
                android:padding="16dp"
                android:layout_margin="4dp">
                <TextView
                    android:id="@+id/tvBlockedCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#FF4757"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Blocked"
                    android:textSize="12sp"
                    android:textColor="#888888"/>
            </LinearLayout>

            <!-- Total Queries -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical"
                android:background="#1A1A2E"
                android:padding="16dp"
                android:layout_margin="4dp">
                <TextView
                    android:id="@+id/tvTotalQueries"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#2ED573"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Queries"
                    android:textSize="12sp"
                    android:textColor="#888888"/>
            </LinearLayout>

            <!-- Block Rate -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical"
                android:background="#1A1A2E"
                android:padding="16dp"
                android:layout_margin="4dp">
                <TextView
                    android:id="@+id/tvBlockRate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.0%"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#FFA502"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Block Rate"
                    android:textSize="12sp"
                    android:textColor="#888888"/>
            </LinearLayout>

            <!-- Domain Count -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical"
                android:background="#1A1A2E"
                android:padding="16dp"
                android:layout_margin="4dp">
                <TextView
                    android:id="@+id/tvDomainCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#747DFA"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Domains Loaded"
                    android:textSize="12sp"
                    android:textColor="#888888"/>
            </LinearLayout>

        </GridLayout>

    </LinearLayout>
</ScrollView>
